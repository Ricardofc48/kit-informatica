<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">.
<meta name="description" content="Kit de Informática 2026 para estudiantes. Guías de HTML, CSS, JavaScript y MySQL con ejercicios y plantillas listas para usar.">
<meta name="keywords" content="kit informatica, estudiar informatica, HTML CSS, programacion dominicana, bachillerato tecnico informatica">
    <title>EduKit — Explora el Futuro</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💻</text></svg>">
    <style>
        /* --- Reset y Tipografía --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        }

        /* Variables de color de la imagen image_3bf2a3.png */
        :root {
            --color-navy: #2F4156;
            --color-teal: #567C8D;
            --color-sky-blue: #C8D9E6;
            --color-beige: #F5EFEB;
            --color-white: #FFFFFF;

            --bg-body: var(--color-beige); 
            --text-main: var(--color-navy); 
            --text-muted: var(--color-teal); 
            
            --grad-primary: linear-gradient(135deg, var(--color-navy) 0%, var(--color-teal) 100%);
            --grad-glow: linear-gradient(135deg, var(--color-teal) 0%, var(--color-sky-blue) 100%);
            
            --shadow-premium: 0 20px 50px rgba(47, 65, 86, 0.15);
            --transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            line-height: 1.6;
            padding: 100px 20px 0 20px;
            overflow-x: hidden;
            position: relative;
        }

        /* --- Fondos Animados Llamativos --- */
        .glow-sphere {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            z-index: -1;
            opacity: 0.6;
            animation: floatSpheres 12s infinite alternate ease-in-out;
        }
        .sphere-1 {
            top: -10%;
            left: -10%;
            width: 500px;
            height: 500px;
            background: var(--color-sky-blue);
        }
        .sphere-2 {
            top: 40%;
            right: -10%;
            width: 600px;
            height: 600px;
            background: var(--color-teal);
            animation-delay: -4s;
        }

        @keyframes floatSpheres {
            0% { transform: translateY(0) scale(1); }
            100% { transform: translateY(40px) scale(1.15); }
        }

        .container {
            max-width: 1140px;
            margin: 0 auto;
            position: relative;
            z-index: 10;
        }

        /* --- Encabezado de Alto Impacto --- */
        header {
            margin-bottom: 80px;
            text-align: center;
        }

        .badge-premium {
            background: var(--color-white);
            color: var(--color-navy);
            border: 1px solid rgba(86, 124, 141, 0.3);
            padding: 6px 18px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            display: inline-block;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.02);
        }

        header h1 {
            font-size: 4.5rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            line-height: 1.1;
            margin-bottom: 20px;
            background: linear-gradient(135deg, var(--color-navy) 20%, var(--color-teal) 70%, var(--color-sky-blue) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        header p {
            color: var(--text-muted);
            font-size: 1.3rem;
            max-width: 650px;
            margin: 0 auto 35px auto;
            font-weight: 400;
        }

        .cta-header {
            display: inline-flex;
            align-items: center;
            background: var(--color-navy);
            color: var(--color-white);
            text-decoration: none;
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 1rem;
            box-shadow: 0 10px 25px rgba(47, 65, 86, 0.25);
            transition: var(--transition);
        }

        .cta-header:hover {
            background: var(--color-teal);
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(86, 124, 141, 0.35);
        }

        /* --- Grid de Misión y Visión Elegante --- */
        .mv-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
            margin-bottom: 100px;
        }

        .mv-box {
            background: rgba(255, 255, 255, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 30px;
            padding: 45px;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 15px 35px rgba(47, 65, 86, 0.03);
            transition: var(--transition);
        }

        .mv-box:hover {
            transform: scale(1.02);
            background: var(--color-white);
            border-color: var(--color-sky-blue);
            box-shadow: var(--shadow-premium);
        }

        .mv-box h2 {
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 15px;
            color: var(--color-navy);
        }

        .mv-box p {
            color: var(--text-muted);
            font-size: 1rem;
            line-height: 1.7;
        }

        /* --- Grid Unión de Tarjetas Estilo "Cards" --- */
        .kits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 40px;
            margin-bottom: 120px;
        }

        .kit-card {
            background: rgba(255, 255, 255, 0.75);
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: 32px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
            transition: var(--transition);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 10px 40px rgba(0,0,0,0.02);
        }

        /* Zoom e iluminación en contenedor de Imagen */
        .kit-image {
            width: 100%;
            height: 240px;
            overflow: hidden;
            position: relative;
        }

        .kit-image::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 40%, rgba(245, 239, 235, 0.9) 100%);
            z-index: 2;
        }

        .kit-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition);
        }

        /* Animaciones Hover sobre Tarjetas */
        .kit-card:hover {
            transform: translateY(-12px);
            border-color: var(--color-sky-blue);
            background: var(--color-white);
            box-shadow: var(--shadow-premium);
        }

        .kit-card:hover .kit-image img {
            transform: scale(1.08);
        }

        /* Contenido de la Tarjeta */
        .kit-content {
            padding: 35px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            justify-content: space-between;
            position: relative;
            z-index: 5;
        }

        .kit-tag {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
            margin-bottom: 20px;
            display: inline-block;
            padding: 6px 16px;
            border-radius: 50px;
            background: var(--color-navy);
            color: var(--color-white);
            box-shadow: 0 4px 10px rgba(47, 65, 86, 0.15);
        }

        .kit-title {
            font-size: 1.6rem;
            font-weight: 700;
            margin-bottom: 14px;
            line-height: 1.3;
            color: var(--color-navy);
        }

        .kit-description {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 35px;
            line-height: 1.7;
        }

        /* Enlaces de Acción Dinámicos */
        .kit-link {
            text-decoration: none;
            color: var(--color-navy);
            font-size: 1rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

        .kit-link .arrow-icon {
            background: rgba(86, 124, 141, 0.1);
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
        }

        .kit-card:hover .kit-link {
            color: var(--color-teal);
        }

        .kit-card:hover .kit-link .arrow-icon {
            background: var(--color-navy);
            color: var(--color-white);
            transform: translateX(5px);
        }

        /* Variación exclusiva de Tag para alternar llamadas de atención */
        .kit-2 .kit-tag { background: var(--color-teal); }
        .kit-3 .kit-tag { background: var(--grad-glow); color: var(--color-navy); }

        /* --- Footer Expansivo --- */
        footer {
            background-color: var(--color-white);
            border-top: 1px solid rgba(86, 124, 141, 0.15);
            padding: 80px 20px 40px 20px;
            margin-top: 60px;
            width: 100vw;
            position: relative;
            left: 50%;
            right: 50%;
            margin-left: -50vw;
            margin-right: -50vw;
        }

        .footer-container {
            max-width: 1140px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 2fr repeat(2, 1fr);
            gap: 50px;
            margin-bottom: 60px;
        }

        .footer-brand h3 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 15px;
            color: var(--color-navy);
        }

        .footer-brand p {
            color: var(--text-muted);
            font-size: 1rem;
            max-width: 360px;
            line-height: 1.7;
        }

        .footer-links h4 {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--color-navy);
        }

        .footer-links ul {
            list-style: none;
        }

        .footer-links ul li {
            margin-bottom: 12px;
        }

        .footer-links ul li a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.95rem;
            transition: var(--transition);
        }

        .footer-links ul li a:hover {
            color: var(--color-navy);
            padding-left: 5px;
        }

        .footer-bottom {
            max-width: 1140px;
            margin: 0 auto;
            border-top: 1px solid rgba(86, 124, 141, 0.1);
            padding-top: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .footer-bottom p {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .footer-legal a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.9rem;
            margin-left: 25px;
            transition: var(--transition);
        }

        .footer-legal a:hover {
            color: var(--color-navy);
        }

        /* --- Diseño Responsivo Óptimo --- */
        @media (max-width: 992px) {
            header h1 { font-size: 3.8rem; }
            .footer-container { grid-template-columns: 1fr 1fr; gap: 40px; }
            .footer-brand { grid-column: span 2; }
        }

        @media (max-width: 768px) {
            header h1 { font-size: 3.2rem; }
            .footer-container { grid-template-columns: 1fr; text-align: center; }
            .footer-brand { grid-column: span 1; }
            .footer-brand p { margin: 0 auto; }
            .footer-bottom { flex-direction: column; text-align: center; }
            .footer-legal a { margin: 0 12px; }
        }

        @media (max-width: 480px) {
            header h1 { font-size: 2.5rem; }
            body { padding-top: 60px; }
            .mv-section { gap: 20px; }
        }
    </style>
</head>
<body>

